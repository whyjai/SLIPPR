NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
CRON_SECRET=your_super_secret_32char_string
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional
DAILY_EMAIL_RECIPIENTS=you@example.com
ODDS_API_KEY=

# --- Real data pipeline ---
# the-odds-api.com (free tier: 500 credits/mo = 2 scans/day; paid unlocks SCAN_HOURS=3)
# ODDS_API_KEY=

# openrouter.ai — one key reaches all 10 free council models.
# Park a one-time $10 credit on the account to unlock 1,000 free-model calls/day.
# OPENROUTER_API_KEY=

# Optional overrides
# SCAN_HOURS=12            # odds scan cadence; set 3 on a paid odds key
# COUNCIL_MODELS=          # comma-separated OpenRouter model ids (max 10)

# --- Payments (Stripe) ---
# STRIPE_SECRET_KEY=sk_live_or_test_...
# STRIPE_PRICE_ID=price_...          # the recurring Pro price
# STRIPE_WEBHOOK_SECRET=whsec_...    # from `stripe listen` or the dashboard webhook
